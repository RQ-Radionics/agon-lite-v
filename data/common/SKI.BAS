   10 REM === SKI GAME FOR AGON LIGHT ===
   20 REM === BBC BASIC / MODE 2 (40x30) ===
   30 PROCchars
   40 PROCtitle
   50 PROCinit
   60 GOTO 300
  100 REM === PROCinit - setup game state ===
  110 DEF PROCinit
  120 MODE 2
  130 VDU 23,1,0:REM hide cursor
  140 COLOUR 143:CLS
  150 VDU 28,0,28,39,2:REM text viewport rows 2-28
  160 X%=20:oldX%=20
  170 SCOR%=0:LVL%=1
  180 YETX%=2:YETY%=RND(20)+2
  190 YETI%=0:dead%=0
  200 dir$=CHR$(205)
  210 COLOUR 10
  220 FOR I%=1 TO 27
  230   PRINT TAB(0,0);CHR$(204);TAB(38,0);CHR$(202)
  240 NEXT
  250 VDU 26
  260 COLOUR 9:PRINT TAB(0,0);"SKI RUN  DISTANCE: 0";
  270 COLOUR 15:PRINT TAB(0,29);STRING$(40,"-");
  280 VDU 28,0,28,39,2
  290 ENDPROC
  300 REM === Main game loop ===
  310 *FX 19
  320 PROCscroll
  330 K%=FN_getKey(50)
  340 oldX%=X%
  350 IF K%=8 AND X%>1 THEN X%=X%-1:dir$=CHR$(201)
  360 IF K%=21 AND X%<38 THEN X%=X%+1:dir$=CHR$(200)
  370 IF K%<>8 AND K%<>21 THEN dir$=CHR$(205)
  380 PROCcollision
  390 IF dead%=1 THEN GOTO 300
  400 PROCdrawPlayer
  410 PROCyeti
  420 SCOR%=SCOR%+1
  430 LVL%=SCOR%/100+1:IF LVL%>10 THEN LVL%=10
  440 VDU 26
  450 COLOUR 9:PRINT TAB(19,0);SCOR%;"  ";
  460 VDU 28,0,28,39,2
  470 GOTO 310
  500 REM === PROCscroll - scroll terrain, generate new row ===
  510 DEF PROCscroll
  520 VDU 26:VDU 28,0,28,39,2
  530 COLOUR 10
  540 PRINT TAB(0,26);CHR$(204);
  550 FOR I%=1 TO 37
  560   IF RND(40)<LVL%+1 AND I%>1 THEN PRINT CHR$(203); ELSE PRINT " ";
  570 NEXT
  580 PRINT CHR$(202);
  590 ENDPROC
  600 REM === PROCdrawPlayer - draw skier at fixed row ===
  610 DEF PROCdrawPlayer
  620 IF oldX%<>X% THEN COLOUR 10:PRINT TAB(oldX%,13);" ";
  630 COLOUR 0:PRINT TAB(X%,13);dir$;
  640 ENDPROC
  700 REM === PROCyeti - update and draw yeti ===
  710 DEF PROCyeti
  720 COLOUR 10
  730 IF YETX%>0 THEN PRINT TAB(YETX%-1,YETY%-1);"   ";
  740 IF YETX%>0 THEN PRINT TAB(YETX%-1,YETY%);"   ";
  750 YETX%=YETX%+1
  760 IF YETX%>40 THEN YETX%=0:YETY%=RND(20)+4
  770 YETY%=YETY%+(RND(3)-2)
  780 IF YETY%<4 THEN YETY%=4
  790 IF YETY%>25 THEN YETY%=25
  800 YETI%=-(YETI%=0)
  810 COLOUR 0
  820 PRINT TAB(YETX%,YETY%-1);CHR$(209+YETI%);
  830 PRINT TAB(YETX%,YETY%);CHR$(211+YETI%);
  840 IF (YETX%=X% AND YETY%-1=13) OR (YETX%=X% AND YETY%=13) THEN PROCyetiAttack
  850 ENDPROC
  900 REM === PROCcollision - check tree collision ===
  910 DEF PROCcollision
  920 dead%=0
  930 C%=GET(X%*8,((13+2)*8)+4)
  940 IF C%=203 THEN PROCspill
  950 ENDPROC
 1000 REM === PROCspill - crash animation ===
 1010 DEF PROCspill
 1020 MX%=-(dir$=CHR$(200))+(dir$=CHR$(201))
 1030 TX%=X%:TY%=13
 1040 FOR A%=1 TO 8
 1050   FOR B%=1 TO 4
 1060     COLOUR 0
 1070     PRINT TAB(TX%,TY%);CHR$(204+B%);
 1080     *FX 19
 1090   NEXT
 1100   TX%=TX%+MX%
 1110   IF TX%<1 THEN TX%=1
 1120   IF TX%>38 THEN TX%=38
 1130   TY%=TY%+1:IF TY%>26 THEN TY%=26
 1140   PRINT TAB(TX%,TY%-1);" ";
 1150 NEXT
 1160 dead%=1
 1170 PROCgameOver
 1180 ENDPROC
 1200 REM === PROCyetiAttack - yeti catches player ===
 1210 DEF PROCyetiAttack
 1220 COLOUR 10
 1230 PRINT TAB(X%-1,12);"   ";
 1240 PRINT TAB(X%-1,13);"   ";
 1250 PRINT TAB(X%-1,14);"   ";
 1260 FOR L%=1 TO 15
 1270   COLOUR 0
 1280   PRINT TAB(X%,13);CHR$(209+YETI%);
 1290   PRINT TAB(X%,14);CHR$(211+YETI%);
 1300   YETI%=-(YETI%=0)
 1310   *FX 19
 1320   *FX 19
 1330   *FX 19
 1340 NEXT
 1350 dead%=1
 1360 PROCgameOver
 1370 ENDPROC
 1400 REM === PROCgameOver - show score and wait ===
 1410 DEF PROCgameOver
 1420 COLOUR 4
 1430 PRINT TAB(11,11);"DISTANCE = ";SCOR%
 1440 PRINT TAB(7,13);"PRESS ANY KEY TO TRY AGAIN"
 1450 REPEAT:T%=INKEY(1):UNTIL T%>0
 1460 PROCinit
 1470 ENDPROC
 1500 REM === FN_getKey - fixed keyboard input ===
 1510 DEF FN_getKey(timeout%)
 1520 A%=&A0
 1530 L%=&17
 1540 keycount%=USR(&FFF4)
 1550 syncs%=timeout%/17
 1560 R%=0
 1570 FOR I%=1 TO syncs%
 1580   L%=&19
 1590   IF keycount%<>USR(&FFF4) THEN L%=&05:R%=USR(&FFF4):I%=syncs%
 1600   IF R%=0 THEN *FX 19
 1610 NEXT
 1620 =R%
 1700 REM === PROCchars - define custom characters ===
 1710 DEF PROCchars
 1720 VDU 23,200,24,16,126,153,24,52,18,9
 1730 VDU 23,201,24,8,126,153,24,44,72,144
 1740 VDU 23,205,24,24,126,153,24,36,36,36
 1750 VDU 23,203,24,60,60,126,126,255,255,24
 1760 VDU 23,204,136,84,36,4,2,2,1,1
 1770 VDU 23,202,17,42,36,32,64,64,128,128
 1780 VDU 23,206,&88,&44,&24,&9D,&7F,&24,&04,&08
 1790 VDU 23,207,&09,&12,&34,&18,&99,&7E,&10,&18
 1800 VDU 23,208,&10,&20,&24,&FE,&B9,&24,&22,&11
 1810 VDU 23,209,&44,&7C,&6D,&45,&C5,&B9,&E6,&A4
 1820 VDU 23,210,&22,&3E,&B6,&A2,&A3,&9D,&67,&25
 1830 VDU 23,211,&24,&24,&64,&5A,&42,&42,&02,&02
 1840 VDU 23,212,&24,&24,&26,&5A,&42,&42,&40,&40
 1850 ENDPROC
 1900 REM === PROCtitle - title screen ===
 1910 DEF PROCtitle
 1920 MODE 2
 1930 COLOUR 143:COLOUR 0:CLS
 1940 VDU 23,1,0
 1950 COLOUR 10
 1960 FOR L%=1 TO 25
 1970   PRINT TAB(0,29);CHR$(204);TAB(38,29);CHR$(202)
 1980 NEXT
 1990 COLOUR 9:PRINT TAB(14,10);"NO SKIING"
 2000 PRINT TAB(11,11);"BEYOND THIS POINT"
 2010 COLOUR 4:PRINT TAB(9,15);"PRESS ANY KEY TO START"
 2020 REPEAT:T%=INKEY(1):UNTIL T%>0
 2030 ENDPROC
